# Example environment for the benchmarking harness (feature 002).
# Copy to .env (gitignored) and adjust. Never commit real secrets or tokens.

# --- environment + auth ---
# development (default): create_all + dev-signed tokens permitted.
# production: Alembic-migrated schema required, OIDC required, dev auth refused.
HARNESS_ENV=development
HARNESS_AUTH_MODE=dev
# local dev signing secret (>=32 bytes). Production ignores this.
HARNESS_DEV_SIGNING_SECRET=change-me-to-a-long-random-dev-only-secret

# OIDC (production): the API validates bearer tokens against this issuer.
# HARNESS_OIDC_ISSUER=https://issuer.example.com
# HARNESS_OIDC_AUDIENCE=harness
# HARNESS_OIDC_ALGORITHMS=RS256
# HARNESS_OIDC_JWKS_URL=            # optional; discovered from the issuer if unset

# --- storage + queue ---
# development default is sqlite; production MUST be postgresql+psycopg://...
HARNESS_DATABASE_URL=sqlite:///harness.db
HARNESS_REDIS_URL=redis://localhost:6379/0

# --- uploads (US3) ---
# Max streamed artifact bytes (413 when exceeded). Keep any reverse proxy's
# body-size limit at least this large. Default 2 GiB.
HARNESS_MAX_UPLOAD_BYTES=2147483648

# --- runner / sandbox ---
HARNESS_SANDBOX_MODE=docker
# Dedicated runner-service boundary (US6/T073). In production, point the API and
# worker at the runner service and give them NO docker.sock of their own; the
# runner is the only socket owner. Leave unset for the in-process dev default.
# HARNESS_RUNNER_URL=http://runner:9000
# HARNESS_RUNNER_TOKEN=change-me-runner-secret   # shared bearer secret for /run

# --- grounding (US5) ---
# Tier 3 visual grounding is MEASURED from localization evidence (pointing game)
# or explicitly unavailable — never a confidence proxy. A model with fewer than
# this many labeled target samples yields "unavailable" (fail-closed → adjudication).
HARNESS_GROUNDING_MIN_SAMPLES=20
# HARNESS_GROUNDING_METHODS=pointing_game,energy_inside_region
